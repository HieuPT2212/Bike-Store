<%- include('partials/header') %>
<link rel="stylesheet" href="/assets/css/bikes.css">

<div style="margin-top: 85px;"></div>

<div class="container py-4 my-3 bg-white shadow-sm rounded-4">
  <nav aria-label="breadcrumb" class="mb-4 px-2">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-decoration-none fw-medium text-primary">Trang chủ</a></li>
      <li class="breadcrumb-item active text-muted" aria-current="page">Hộp thư cá nhân</li>
    </ol>
  </nav>

  <div class="row">
    <div class="col-12 px-lg-4">
      <h4 class="fw-bold mb-4 text-dark border-bottom pb-3"><i class="fa-solid fa-inbox me-2 text-primary"></i> Hộp thư của bạn</h4>

      <% if(typeof error_msg !== 'undefined' && error_msg) { %>
        <div class="alert alert-danger rounded-3"><i class="fa-solid fa-triangle-exclamation me-2"></i> <%= error_msg %></div>
      <% } %>
      <% if(typeof success_msg !== 'undefined' && success_msg) { %>
        <div class="alert alert-success rounded-3"><i class="fa-solid fa-circle-check me-2"></i> <%= success_msg %></div>
      <% } %>

      <% if(messages && messages.length > 0) { %>
        <div class="list-group list-group-flush border rounded-3">
          <% messages.forEach(function(msg) { %>
            <% const isSentByMe = (msg.sender_id === currentUserId); %>
            <% const otherUserAvatar = isSentByMe ? msg.receiver_avatar : msg.sender_avatar; %>
            <% const otherUserName = isSentByMe ? msg.receiver_name : msg.sender_name; %>
            <% const otherUserId = isSentByMe ? msg.receiver_id : msg.sender_id; %>

            <div class="list-group-item list-group-item-action d-flex flex-column flex-md-row gap-3 p-4 align-items-md-center <%= !isSentByMe ? 'bg-light' : '' %>">
              <img src="<%= otherUserAvatar %>" alt="Avatar" class="rounded-circle object-fit-cover shadow-sm" width="60" height="60">
              <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <h6 class="mb-0 fw-bold <%= !isSentByMe ? 'text-primary' : 'text-dark' %>">
                    <%= isSentByMe ? 'Bạn đã gửi cho ' : 'Nhận từ ' %> <%= otherUserName %>
                  </h6>
                  <small class="text-muted"><i class="fa-regular fa-clock me-1"></i> <%= new Date(msg.created_at).toLocaleString('vi-VN') %></small>
                </div>
                <p class="mb-2 text-muted small"><i class="fa-solid fa-bicycle me-1"></i> Liên quan đến xe: <a href="/bike/<%= msg.bike_id %>" class="fw-medium text-decoration-none"><%= msg.bike_name %></a></p>
                <div class="p-3 bg-white rounded-3 border <%= isSentByMe ? 'border-primary border-opacity-25' : '' %>" style="font-size: 0.95rem;">
                  <%= msg.content %>
                </div>
              </div>
              
              <!-- Nút Phản Hồi -->
              <div class="ms-md-3 mt-3 mt-md-0 d-flex flex-column align-items-center justify-content-center">
                <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#replyModal<%= msg.id %>">
                  <i class="fa-solid fa-reply me-1"></i> Phản hồi
                </button>
              </div>
            </div>

            <!-- Modal Phản Hồi cho từng tin nhắn -->
            <div class="modal fade" id="replyModal<%= msg.id %>" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog">
                <form action="/message/<%= msg.bike_id %>" method="POST">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title fw-bold text-primary">Phản hồi tới <%= otherUserName %></h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                      <input type="hidden" name="receiver_id" value="<%= otherUserId %>">
                      <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung tin nhắn</label>
                        <textarea name="content" class="form-control" rows="4" required placeholder="Nhập câu trả lời của bạn..."></textarea>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                      <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane me-2"></i> Gửi Tin Nhắn</button>
                    </div>
                  </div>
                </form>
              </div>
            </div>

          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center py-5">
          <div class="p-5 bg-light border rounded-4 border-dashed">
            <i class="fa-regular fa-comments fa-4x text-secondary mb-3 opacity-50"></i>
            <h5 class="text-dark fw-bold">Hộp thư trống!</h5>
            <p class="text-muted">Bạn chưa có cuộc trò chuyện nào. Hãy tìm kiếm xe và liên hệ với người bán.</p>
          </div>
        </div>
      <% } %>

    </div>
  </div>
</div>

<%- include('partials/footer') %>

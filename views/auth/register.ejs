<%- include('../partials/header') %>
  <!-- Sử dụng lại bộ xương CSS của Form Đăng nhập để đảm bảo tính đồng bộ -->
  <link rel="stylesheet" href="/assets/css/login.css">

  <div class="login-wrapper">
    <div class="container my-5">
      <div class="row w-100 mx-0 justify-content-center">
        <div class="col-12 col-md-10 col-lg-8 col-xl-6 px-0">
          <div class="login-card card border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="card-body p-4 p-md-5">
              <div class="text-center mb-4">
                <a href="/" class="text-decoration-none d-inline-block mb-3">
                  <h3 class="fw-bold mb-0 text-dark brand-logo">
                    <i class="fa-solid fa-bicycle text-primary me-2"></i>Crank<span class="text-primary">Up</span>
                  </h3>
                </a>
                <h5 class="fw-bold text-dark">Đăng Ký Tài Khoản Mới</h5>
                <p class="text-muted small">Tham gia cộng đồng mua bán xe đạp thể thao lớn nhất</p>
              </div>

              <!-- Khối Báo Lỗi Động từ Server -->
              <% if(error_msg) { %>
                <div class="alert alert-danger py-2 small fw-medium"><i class="fa-solid fa-circle-exclamation me-1"></i>
                  <%= error_msg %>
                </div>
                <% } %>

                  <form action="/register" method="POST">

                    <div class="row g-3 mb-3">
                      <div class="col-md-6">
                        <label for="full_name" class="form-label text-muted fw-medium small mb-1">Họ và Tên</label>
                        <div class="input-group">
                          <span class="input-group-text bg-light border-end-0 text-muted"><i
                              class="fa-regular fa-user"></i></span>
                          <input type="text" class="form-control bg-light border-start-0 ps-0 shadow-none py-2"
                            id="full_name" name="full_name" placeholder="Ví dụ: Hoàng Anh" required>
                        </div>
                      </div>
                      <div class="col-md-6">
                        <label for="phone" class="form-label text-muted fw-medium small mb-1">Số điện thoại liên
                          hệ</label>
                        <div class="input-group">
                          <span class="input-group-text bg-light border-end-0 text-muted"><i
                              class="fa-solid fa-phone"></i></span>
                          <input type="tel" class="form-control bg-light border-start-0 ps-0 shadow-none py-2"
                            id="phone" name="phone" placeholder="0987xxx..." required>
                        </div>
                      </div>
                    </div>

                    <div class="mb-3">
                      <label for="email" class="form-label text-muted fw-medium small mb-1">Địa chỉ Email (Dùng để đăng
                        nhập)</label>
                      <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i
                            class="fa-regular fa-envelope"></i></span>
                        <input type="email" class="form-control bg-light border-start-0 ps-0 shadow-none py-2"
                          id="email" name="email" placeholder="example@gmail.com" required>
                      </div>
                    </div>

                    <div class="mb-4">
                      <label class="form-label text-muted fw-medium small mb-1">Vai Trò (Bạn tham gia CrankUp để làm
                        gì?)</label>
                      <div class="d-flex flex-column flex-sm-row gap-3">
                        <div class="form-check border rounded-3 p-3 flex-grow-1 cursor-pointer bg-light role-selector"
                          onclick="document.getElementById('roleBuyer').click()" style="cursor: pointer;">
                          <input class="form-check-input ms-0 mt-0 me-2" type="radio" name="role" id="roleBuyer"
                            value="Buyer" checked>
                          <label class="form-check-label fw-bold text-dark mt-0 pt-0" for="roleBuyer"
                            style="cursor: pointer;">Khách Hàng</label>
                          <div class="small text-muted mt-1">Tôi muốn tìm và đặt mua xe</div>
                        </div>
                        <div class="form-check border rounded-3 p-3 flex-grow-1 cursor-pointer bg-light role-selector"
                          onclick="document.getElementById('roleSeller').click()" style="cursor: pointer;">
                          <input class="form-check-input ms-0 mt-0 me-2" type="radio" name="role" id="roleSeller"
                            value="Seller">
                          <label class="form-check-label fw-bold text-dark mt-0 pt-0" for="roleSeller"
                            style="cursor: pointer;">Người Bán</label>
                          <div class="small text-muted mt-1">Tôi là cá nhân/Cửa hàng bán xe</div>
                        </div>
                      </div>
                    </div>

                    <div class="row g-3 mb-4">
                      <div class="col-md-6">
                        <label for="password" class="form-label text-muted fw-medium small mb-1">Mật khẩu</label>
                        <div class="input-group">
                          <span class="input-group-text bg-light border-end-0 text-muted"><i
                              class="fa-solid fa-lock"></i></span>
                          <input type="password" class="form-control bg-light border-start-0 ps-0 shadow-none py-2"
                            id="password" name="password" placeholder="Nhập ít nhất 6 ký tự" required>
                        </div>
                      </div>
                      <div class="col-md-6">
                        <label for="confirm_password" class="form-label text-muted fw-medium small mb-1">Xác nhận lại
                          mật khẩu</label>
                        <div class="input-group">
                          <span class="input-group-text bg-light border-end-0 text-muted"><i
                              class="fa-solid fa-lock"></i></span>
                          <input type="password" class="form-control bg-light border-start-0 ps-0 shadow-none py-2"
                            id="confirm_password" name="confirm_password" placeholder="Gõ lại cho khớp" required>
                        </div>
                      </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 mb-3 fw-bold shadow-sm rounded-3 fs-5">
                      Mở Tài Khoản Mới
                    </button>

                    <div class="text-center mt-3">
                      <span class="text-muted small">Đã có tài khoản sẵn rồi?</span>
                      <a href="/login" class="fw-bold text-primary text-decoration-none ms-1 hover-underline">Quay lại
                        Đăng nhập</a>
                    </div>
                  </form>

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .role-selector {
      transition: 0.2s;
      border-width: 2px !important;
    }

    .role-selector:hover {
      border-color: var(--primary-color) !important;
      background-color: #fff !important;
    }
  </style>

  <%- include('../partials/footer') %>